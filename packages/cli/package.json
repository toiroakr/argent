{
  "name": "@toiroakr/argent",
  "version": "0.6.5",
  "description": "Assess the risk of an npm package before you install it — deps.dev, OpenSSF Scorecard, socket.dev and Snyk Advisor in one command.",
  "type": "module",
  "bin": {
    "argent": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "npm",
    "security",
    "supply-chain",
    "audit",
    "socket.dev",
    "deps.dev",
    "openssf",
    "scorecard",
    "snyk"
  ],
  "homepage": "https://github.com/toiroakr/argent#readme",
  "bugs": "https://github.com/toiroakr/argent/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toiroakr/argent.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@argent/core": "workspace:*",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
