{
  "name": "argent",
  "version": "0.1.0",
  "description": "Assess the risk of an npm package before you install it — deps.dev, OpenSSF Scorecard, socket.dev and Snyk Advisor in one command.",
  "type": "module",
  "bin": {
    "argent": "./dist/index.js"
  },
  "files": ["dist"],
  "keywords": [
    "npm",
    "security",
    "supply-chain",
    "audit",
    "socket.dev",
    "deps.dev",
    "openssf",
    "scorecard",
    "snyk"
  ],
  "scripts": {
    "build": "tsup",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@argent/core": "workspace:*",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
